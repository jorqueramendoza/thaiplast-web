---
import Icon from './Icon.astro';
import { site } from '../lib/site';
import { waListaPrecios } from '../lib/whatsapp';

const nav = [
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/industrias', label: 'Industrias' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];
const lista = waListaPrecios('header');
---
<header class="hdr">
  <div class="container hdr__row">
    <a href="/" class="hdr__brand" aria-label={`${site.nombre} — inicio`}>
      <img src="/img/brand/logo.jpg" width="46" height="46" alt={`Logo ${site.nombre}`} class="hdr__logo" />
      <span class="hdr__name">{site.nombre}<small>{site.tagline}</small></span>
    </a>

    <nav class="hdr__nav" aria-label="Principal">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>

    <div class="hdr__actions">
      <a href="/pedido" class="hdr__cart" aria-label="Ver mi pedido">
        <Icon name="cart" size={22} />
        <span class="hdr__cartbadge" data-cart-count hidden>0</span>
      </a>
      <a href={lista} class="btn btn--red hdr__cta" target="_blank" rel="noopener">Solicitar precios</a>
      <button class="hdr__burger" aria-label="Abrir menú" aria-expanded="false" data-menu-toggle>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="hdr__mobile" data-menu hidden>
    <nav aria-label="Móvil">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <a href="/pedido">Armar pedido</a>
    </nav>
    <a href={lista} class="btn btn--red btn--block" target="_blank" rel="noopener">Solicitar lista de precios</a>
  </div>
</header>

<style>
  .hdr { position: sticky; top: 0; z-index: var(--z-header); background: rgba(255,255,255,.92); backdrop-filter: blur(8px); border-bottom: 1px solid var(--tp-line); }
  .hdr__row { display: flex; align-items: center; gap: 1rem; min-height: 64px; }
  .hdr__brand { display: flex; align-items: center; gap: .6rem; margin-right: auto; }
  .hdr__logo { border-radius: 50%; box-shadow: var(--shadow-sm); }
  .hdr__name { display: flex; flex-direction: column; font-weight: 800; color: var(--tp-navy); line-height: 1; font-size: 1.15rem; }
  .hdr__name small { font-weight: 500; font-size: .62rem; letter-spacing: .04em; color: var(--tp-gold); text-transform: uppercase; }
  .hdr__nav { display: none; gap: 1.4rem; font-weight: 600; color: var(--tp-navy); }
  .hdr__nav a:hover { color: var(--tp-red); }
  .hdr__actions { display: flex; align-items: center; gap: .6rem; }
  .hdr__cart { position: relative; display: inline-flex; padding: .4rem; color: var(--tp-navy); }
  .hdr__cart:hover { color: var(--tp-red); }
  .hdr__cartbadge { position: absolute; top: -2px; right: -4px; background: var(--tp-red); color: #fff; font-size: .65rem; font-weight: 700; min-width: 17px; height: 17px; padding: 0 4px; border-radius: 999px; display: grid; place-items: center; }
  .hdr__cta { display: none; }
  .hdr__burger { display: inline-flex; flex-direction: column; gap: 4px; background: none; border: 0; padding: .5rem; }
  .hdr__burger span { width: 22px; height: 2px; background: var(--tp-navy); border-radius: 2px; transition: .2s; }
  .hdr__burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hdr__burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .hdr__burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  .hdr__mobile { border-top: 1px solid var(--tp-line); padding: var(--gutter); display: grid; gap: 1rem; background: #fff; }
  .hdr__mobile nav { display: grid; gap: .3rem; font-weight: 600; font-size: 1.05rem; }
  .hdr__mobile nav a { padding: .6rem .2rem; border-bottom: 1px solid var(--tp-line); }

  @media (min-width: 880px) {
    .hdr__nav { display: flex; }
    .hdr__cta { display: inline-flex; }
    .hdr__burger, .hdr__mobile { display: none !important; }
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-menu]');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) (menu as HTMLElement).hidden = open;
  });

  // Badge del carrito (lee localStorage sin importar el módulo para mantenerlo mínimo)
  import { onCartChange, count } from '../lib/cart';
  const badge = document.querySelector('[data-cart-count]') as HTMLElement | null;
  function paint() {
    if (!badge) return;
    const n = count();
    badge.textContent = String(n);
    badge.hidden = n === 0;
  }
  paint();
  onCartChange(paint);
</script>
