---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { totalProducts } from '../lib/products';
import { waListaPrecios } from '../lib/whatsapp';
const lista = waListaPrecios('pagina-lista-precios');
---
<BaseLayout
  title="Solicitar lista de precios"
  description="Pide la lista de precios actualizada de ThaiPlast por WhatsApp. Precios por mayor para negocios, revendedores y empresas."
>
  <section class="section">
    <div class="container narrow">
      <div class="lp card">
        <span class="lp__icon"><Icon name="doc" size={40} /></span>
        <h1>Lista de precios actualizada</h1>
        <p class="lead">
          Tenemos {totalProducts} productos con precios por mayor. Te enviamos la lista completa
          y actualizada directo por WhatsApp, junto a un asesor que resuelve tus dudas.
        </p>
        <ul class="lp__list">
          <li><Icon name="check" size={18} /> Precios por mayor para negocios y revendedores</li>
          <li><Icon name="check" size={18} /> Atención directa, sin formularios eternos</li>
          <li><Icon name="check" size={18} /> Despacho coordinado en Santiago y RM</li>
        </ul>
        <a href={lista} class="btn btn--wa btn--lg btn--block" target="_blank" rel="noopener">
          <Icon name="whatsapp" size={22} /> Pedir lista por WhatsApp
        </a>
        <a href="/catalogo" class="btn btn--ghost btn--block">Mientras tanto, ver el catálogo</a>
        <p class="lp__alt">¿Prefieres revisar el catálogo PDF? <a href="/catalogo-thaiplast.pdf" target="_blank" rel="noopener">Descárgalo aquí</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .narrow { max-width: 640px; }
  .lp { padding: clamp(28px, 5vw, 48px); text-align: center; display: grid; gap: 1rem; justify-items: center; }
  .lp__icon { display: grid; place-items: center; width: 78px; height: 78px; border-radius: 50%; background: linear-gradient(135deg, var(--tp-gold), var(--tp-gold-light)); color: #3a2800; }
  .lp__list { list-style: none; padding: 0; display: grid; gap: .5rem; text-align: left; color: var(--tp-ink); }
  .lp__list li { display: flex; align-items: center; gap: .5rem; }
  .lp__list :global(svg) { color: var(--wa-green); flex: none; }
  .lp__alt { font-size: .85rem; color: var(--tp-muted); }
  .lp__alt a { color: var(--tp-red); font-weight: 600; }
</style>
