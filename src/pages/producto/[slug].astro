---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Icon from '../../components/Icon.astro';
import { products, related } from '../../lib/products';
import { waProducto, waListaPrecios } from '../../lib/whatsapp';
import { site } from '../../lib/site';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}
const { p } = Astro.props;
const wa = waProducto(p);
const lista = waListaPrecios(`producto-${p.slug}`);
const rel = related(p);

const specs = [
  ['Categoría', p.categoria],
  ['Medida / Capacidad', p.medida],
  ['Presentación', p.presentacion],
  ['Color', p.color],
  ['Material', p.material],
  ['Uso recomendado', p.uso],
  ['SKU', p.sku],
].filter(([, v]) => v);

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: p.nombre,
  sku: p.sku,
  category: p.categoria,
  description: p.descripcion,
  image: new URL(p.imagen, site.url).href,
  brand: { '@type': 'Brand', name: site.nombre },
  ...(p.precio != null && {
    offers: {
      '@type': 'Offer',
      price: p.precio,
      priceCurrency: 'CLP',
      availability: 'https://schema.org/InStock',
      url: new URL(`/producto/${p.slug}`, site.url).href,
      seller: { '@type': 'Organization', name: site.nombre },
    },
  }),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Catálogo', item: `${site.url}/catalogo` },
    { '@type': 'ListItem', position: 3, name: p.grupo_nombre, item: `${site.url}/catalogo/${p.grupo}` },
    { '@type': 'ListItem', position: 4, name: p.nombre, item: `${site.url}/producto/${p.slug}` },
  ],
};
---
<BaseLayout
  title={p.nombre}
  description={`${p.descripcion} Precio referencial ${p.precio_formato}. Pide por mayor en ThaiPlast por WhatsApp.`}
  image={p.imagen}
  jsonLd={[productLd, breadcrumbLd]}
>
  <section class="section">
    <div class="container">
      <nav class="crumbs" aria-label="Migas de pan">
        <a href="/">Inicio</a> <span>/</span>
        <a href="/catalogo">Catálogo</a> <span>/</span>
        <a href={`/catalogo/${p.grupo}`}>{p.grupo_nombre}</a> <span>/</span>
        <strong>{p.nombre}</strong>
      </nav>

      <div class="prod">
        <div class="prod__media card">
          <img src={p.imagen} alt={p.nombre} width="500" height="500" />
          <span class="prod__cat">{p.categoria}</span>
        </div>

        <div class="prod__info">
          <h1>{p.nombre}</h1>
          <p class="prod__price">{p.precio_formato} <small>precio referencial · {p.unidad_venta}</small></p>
          <p class="prod__desc">{p.descripcion}</p>

          <div class="prod__cta">
            <button
              class="btn btn--blue btn--lg"
              data-add-to-cart
              data-id={p.id} data-slug={p.slug} data-sku={p.sku}
              data-nombre={p.nombre} data-presentacion={p.presentacion}
              data-precio={p.precio ?? ''} data-imagen={p.imagen}
            ><Icon name="cart" size={20} /> Agregar al pedido</button>
            <a class="btn btn--wa btn--lg" href={wa} target="_blank" rel="noopener"><Icon name="whatsapp" size={20} /> Consultar por WhatsApp</a>
          </div>
          <a class="prod__lista" href={lista} target="_blank" rel="noopener"><Icon name="doc" size={18} /> Solicitar lista de precios completa</a>

          <table class="specs">
            <tbody>
              {specs.map(([k, v]) => (<tr><th>{k}</th><td>{v}</td></tr>))}
            </tbody>
          </table>
        </div>
      </div>

      {rel.length > 0 && (
        <div class="related">
          <h2>También te puede servir</h2>
          <ul class="catgrid">
            {rel.map((r) => <li><ProductCard product={r} /></li>)}
          </ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .crumbs { font-size: .85rem; color: var(--tp-muted); margin-bottom: 1.2rem; }
  .crumbs a:hover { color: var(--tp-red); }
  .crumbs span { margin: 0 .35rem; }
  .prod { display: grid; gap: clamp(20px, 4vw, 44px); grid-template-columns: 1fr; }
  .prod__media { position: relative; aspect-ratio: 1; display: grid; place-items: center; background: #f1f4fb; overflow: hidden; }
  .prod__media img { width: 70%; height: 70%; object-fit: contain; }
  .prod__cat { position: absolute; top: 12px; left: 12px; background: rgba(11,27,69,.85); color: #fff; font-size: .72rem; font-weight: 600; padding: .25rem .7rem; border-radius: var(--r-pill); }
  .prod__info h1 { margin-bottom: .6rem; }
  .prod__price { font-size: 2rem; font-weight: 800; color: var(--tp-red); margin-bottom: .8rem; }
  .prod__price small { display: block; font-size: .8rem; font-weight: 500; color: var(--tp-muted); }
  .prod__desc { color: var(--tp-muted); margin-bottom: 1.4rem; }
  .prod__cta { display: grid; gap: .6rem; grid-template-columns: 1fr; margin-bottom: .8rem; }
  .prod__lista { display: inline-flex; align-items: center; gap: .4rem; color: var(--tp-blue); font-weight: 600; font-size: .92rem; margin-bottom: 1.4rem; }
  .prod__lista:hover { color: var(--tp-red); }
  .specs { width: 100%; border-collapse: collapse; font-size: .92rem; }
  .specs th { text-align: left; color: var(--tp-muted); font-weight: 600; padding: .55rem .8rem .55rem 0; width: 42%; vertical-align: top; }
  .specs td { padding: .55rem 0; border-bottom: 1px solid var(--tp-line); }
  .specs tr:first-child th, .specs tr:first-child td { border-top: 1px solid var(--tp-line); }
  .related { margin-top: clamp(40px, 7vw, 72px); }
  .related h2 { margin-bottom: 1.2rem; }
  .catgrid { list-style: none; padding: 0; display: grid; gap: clamp(12px, 2vw, 20px); grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 720px) {
    .prod { grid-template-columns: 1fr 1fr; align-items: start; }
    .prod__cta { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 980px) { .catgrid { grid-template-columns: repeat(4, 1fr); } }
</style>
