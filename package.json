{
  "name": "thaiplast-web",
  "version": "1.0.0",
  "description": "Sitio web B2B ThaiPlast — catálogo de desechables con generación de leads por WhatsApp",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run import && astro build",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "validate": "node scripts/validate-products.mjs",
    "import": "node scripts/import-products.mjs",
    "import:xlsx": "node scripts/import-products.mjs --xlsx",
    "extract:catalogo": "node scripts/extract-catalog-images.mjs",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "wrangler": "^4.103.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "vite": "^7"
  }
}
